{
  "expo": {
    "name": "BIKE SEGURA BC",
    "slug": "bike-segura-bc",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "bikesegurabc",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.bikesegurabc.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Tirar fotos da bicicleta",
        "NSPhotoLibraryUsageDescription": "Selecionar fotos da bicicleta",
        "LSApplicationQueriesSchemes": ["whatsapp", "https", "http", "tel"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#FFC107"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#4CAF50"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Permite acessar galeria para fotos da bike"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
