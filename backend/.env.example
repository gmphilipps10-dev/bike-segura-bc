NODE_ENV=production
PORT=3000

# Banco de dados
MONGODB_URI=mongodb+srv://USUARIO:SENHA@CLUSTER/bike-segura

# Gere valores longos, aleatorios e diferentes para cada segredo
JWT_SECRET=COLOQUE_UMA_CHAVE_LONGA_E_ALEATORIA
QR_SALT=COLOQUE_OUTRA_CHAVE_LONGA_E_ALEATORIA

# Dominios autorizados, separados por virgula
CORS_ORIGINS=https://www.bikesegurabc.com.br,https://bikesegurabc.com.br,https://forcasdeseguranca.bikesegurabc.com.br

# Painel administrativo
PAINEL_SENHA=COLOQUE_UMA_SENHA_FORTE
ADMIN_PIN=COLOQUE_UM_PIN_FORTE
ENABLE_ADMIN_PROMOTION=false

# Asaas
ASAAS_ENV=production
ASAAS_API_KEY=COLOQUE_A_CHAVE_DO_ASAAS
ASAAS_WEBHOOK_TOKEN=COLOQUE_UM_TOKEN_LONGO_E_ALEATORIO

# Push notifications, se estiverem em uso
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:contato@bikesegurabc.com.br
