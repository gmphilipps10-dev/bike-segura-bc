# ==========================================
# Bike Segura BC - Variáveis de Ambiente
# ==========================================

# MongoDB Atlas
MONGODB_URI=mongodb+srv://usuario:senha@cluster.mongodb.net/bike-segura-bc?retryWrites=true&w=majority

# JWT (gerar com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=sua-chave-jwt-super-secreta-aqui

# VAPID Keys para Push Notifications (gerar com: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=chave-publica-vapid
VAPID_PRIVATE_KEY=chave-privada-vapid

# Asaas (Pagamentos)
ASAAS_API_KEY=sua-chave-asaas

# ==========================================
# EVOLUTION API (WhatsApp Integration)
# ==========================================

# URL interna da Evolution API (Docker)
EVOLUTION_API_URL=http://evolution:8080

# Chave de API da Evolution (defina uma senha forte)
EVOLUTION_API_KEY=bike-segura-bc-2024

# URL pública do seu servidor (usada pelo webhook)
# Exemplo: https://bike-segura-bc.ondigitalocean.app
WEBHOOK_BASE_URL=https://seu-dominio-da-digitalocean.com
